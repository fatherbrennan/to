{
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.49.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.9",
    "eruda": "^3.4.3",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "sveltekit-superforms": "^2.29.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "valibot": "^1.2.0",
    "vite": "^7.2.6"
  },
  "name": "to",
  "private": true,
  "scripts": {
    "build": "bun --bun vite build",
    "check": "bun --bun svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun --bun svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "bun --bun vite dev",
    "format": "biome format --write",
    "format.check": "biome check",
    "format.check.verbose": "biome check --verbose",
    "format.fix": "biome check --fix --unsafe",
    "lint": "biome lint --write",
    "lint.check": "biome lint",
    "prepare": "bun --bun svelte-kit sync || printf '\n'",
    "preview": "bun --bun vite preview --open",
    "start": "bun --bun ./build/index.js",
    "test": "bun test --watch"
  },
  "type": "module",
  "version": "0.0.1"
}
