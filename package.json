{
  "description": "notes.",
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@builder.io/qwik": "^1.19.0",
    "@builder.io/qwik-city": "^1.19.0",
    "@modular-forms/qwik": "^0.29.1",
    "@qwik-ui/headless": "^0.7.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.8",
    "eruda": "^3.4.3",
    "eslint-plugin-qwik": "^1.19.0",
    "tailwindcss": "^4.1.18",
    "typescript": "5.9.3",
    "valibot": "^1.2.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.3"
  },
  "engines": {
    "node": "^18.17.0 || ^20.3.0 || >=21.0.0"
  },
  "engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
  "name": "to",
  "private": true,
  "scripts": {
    "build": "qwik build",
    "build.client": "bun vite build",
    "build.preview": "bun vite build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vite build -c adapters/static/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "clear": "rm -rf node_modules dist server temp",
    "dev": "bun --bun vite --mode ssr --host",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "format": "biome format --write",
    "format.check": "biome check",
    "format.check.verbose": "biome check --verbose",
    "format.fix": "biome check --fix --unsafe",
    "lint": "biome lint --write",
    "lint.check": "biome lint",
    "preview": "qwik build preview && vite preview --open --host",
    "qwik": "qwik",
    "start": "bun server/entry.bun.js",
    "start.python": "python3 -m http.server 8080 --bind 127.0.0.1 --directory dist",
    "test": "bun test --watch"
  },
  "trustedDependencies": ["sharp"],
  "trustedDependencies-annotation": "Needed for bun to allow running install scripts",
  "type": "module"
}
